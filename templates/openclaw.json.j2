{# ============================================================ #}
{# openclaw.json.j2 -- OpenClaw Gateway 主配置文件模板           #}
{# 输出 JSON5 格式，支持注释和尾部逗号                             #}
{# ============================================================ #}
// OpenClaw Gateway Configuration
// Generated by loop-openclaw render.py
// Mode: {{ mode }}
// Project: {{ project_name }}
// Date: {{ generated_at }}

{
  "$schema": "https://openclaw.ai/schemas/gateway-config.json",

  // ---- 项目元数据 ----
  "version": "1.0",
  "project": "{{ project_name }}",
  "description": "Loop configuration – mode: {{ mode }} – {{ mode_description }}",
  "generated_by": "loop-openclaw render.py {{ generator_version }}",
  "generated_at": "{{ generated_at }}",

  // ---- Agent 定义 ----
  "agents": [
{% for agent in agents %}
    {
      "id": "{{ agent.id }}",
      "role": "{{ agent.role }}",
      "model": "{{ agent.model or model_name }}",
      "model_provider": "{{ model_provider }}",
      "temperature": {{ agent.get('temperature', temperature) }},
      "max_tokens": {{ agent.get('max_tokens', max_tokens) }},
      "description": "{{ agent.description or (agent.role + ' agent for ' + project_name) }}",
      "system_prompt_files": [
        "SOUL.md",
        "IDENTITY.md",
        "TOOLS.md",
        "AGENTS.md"
      ],
      "permissions": {{ (agent.permissions if agent.permissions is defined else {}) | tojson }}
    }{% if not loop.last %},{% endif %}
{% endfor %}
  ],

  // ---- 频道配置 ----
  "channels": {{ channels | tojson }},

  // ---- 路由规则 ----
  "routing": {{ routing_rules | tojson }},

  // ---- Loop 配置 ----
  "settings": {
    "mode": "{{ mode }}",
    "max_cycles": {{ max_cycles }},
    "convergence_rounds": {{ convergence_rounds }},
    "max_duration_minutes": {{ max_duration_minutes }}
  },

  // ---- 元数据（扩展字段） ----
  "metadata": {
    "orchestrator_id": "{{ orchestrator_id }}",
    "worker_ids": {{ worker_ids | tojson }},
    "topology": "{{ mode }}"
  }
}
